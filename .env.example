# Binance API
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Trading Config
TRADING_SYMBOL=BTCUSDT
TRADING_INTERVAL=1h
TRADING_QUANTITY=0.001

# Mode: paper (simulasi) atau live
TRADING_MODE=paper

# Strategy: rsi, macd, bollinger, combined
STRATEGY=combined

# Risk Management
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=4.0
MAX_POSITION_SIZE=100.0

# Logging
LOG_LEVEL=INFO
